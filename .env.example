# Optional for local development. If both are set, DATABASE_URL is used.
DATABASE_URL=
SUPABASE_DATABASE_URL=

# App runtime
NODE_ENV=development

# Auth mode
# In production, default is false unless explicitly enabled.
DEMO_AUTH_ENABLED=true
# Optional client-side mirror for login UI toggle.
NEXT_PUBLIC_DEMO_AUTH_ENABLED=true

# Session cookie config
SESSION_COOKIE_NAME=buyeros-session
PORTAL_SESSION_COOKIE_NAME=buyeros-portal-session
SESSION_MAX_AGE_SECONDS=604800

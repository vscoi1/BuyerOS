{
  "name": "buyersos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "lint": "npm run lint --workspace web",
    "typecheck": "npm run typecheck --workspace web",
    "test": "npm run test --workspace web",
    "build": "npm run build --workspace web",
    "db:generate": "npm run db:generate --workspace @buyersos/db",
    "db:migrate": "npm run db:migrate --workspace @buyersos/db",
    "db:generate:supabase": "DATABASE_URL=\"$SUPABASE_DATABASE_URL\" npm run db:generate",
    "db:migrate:supabase": "DATABASE_URL=\"$SUPABASE_DATABASE_URL\" npm run db:migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
